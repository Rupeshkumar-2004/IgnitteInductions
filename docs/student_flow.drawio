<mxGraphModel adaptiveColors="auto">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>
    <mxCell id="lane_fe" value="Frontend (Pages &amp; UI Components)" style="swimlane;horizontal=0;startSize=110;fillColor=#f5f5f5;html=1;" vertex="1" parent="1">
      <mxGeometry x="0" y="0" width="1800" height="150" as="geometry"/>
    </mxCell>
    <mxCell id="lane_mid" value="Routing &amp; Security Middleware" style="swimlane;horizontal=0;startSize=110;fillColor=#e8f4f8;html=1;" vertex="1" parent="1">
