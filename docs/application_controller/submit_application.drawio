<mxGraphModel adaptiveColors="auto">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>
    <mxCell id="lane_client" value="Client / Frontend" style="swimlane;horizontal=0;startSize=110;fillColor=#f5f5f5;html=1;" vertex="1" parent="1">
      <mxGeometry x="0" y="0" width="1170" height="150" as="geometry"/>
    </mxCell>
    <mxCell id="lane_route" value="Router &amp; Middleware" style="swimlane;horizontal=0;startSize=110;fillColor=#e8f4f8;html=1;" vertex="1" parent="1">
      <mxGeometry x="0" y="150" width="1170" height="150" as="geometry"/>
    </mxCell>
    <mxCell id="lane_controller" value="Application Controller" style="swimlane;horizontal=0;startSize=110;fillColor=#fff0e6;html=1;" vertex="1" parent="1">
      <mxGeometry x="0" y="300" width="1170" height="150" as="geometry"/>
    </mxCell>
    <mxCell id="lane_db" value="Database (MongoDB)" style="swimlane;horizontal=0;startSize=110;fillColor=#e8f5e9;html=1;" vertex="1" parent="1">
      <mxGeometry x="0" y="450" width="1170" height="150" as="geometry"/>
    </mxCell>
    <mxCell id="start" value="Student fills form &amp; submits" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="lane_client">
      <mxGeometry x="120" y="45" width="140" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="route" value="POST /api/v1/applications/" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="lane_route">
      <mxGeometry x="300" y="45" width="140" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="jwt" value="verifyJWT &amp; Zod Schema Validate" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="lane_route">
      <mxGeometry x="480" y="45" width="140" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="check_exist" value="Check existing application" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="lane_controller">
      <mxGeometry x="660" y="45" width="140" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="db_check" value="Application.findOne({ user: id })" style="shape=cylinder3;whiteSpace=wrap;html=1;" vertex="1" parent="lane_db">
      <mxGeometry x="680" y="40" width="100" height="70" as="geometry"/>
    </mxCell>
    <mxCell id="create_app" value="Application.create(payload)" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="lane_controller">
      <mxGeometry x="840" y="45" width="140" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="db_insert" value="Insert Application Document" style="shape=cylinder3;whiteSpace=wrap;html=1;" vertex="1" parent="lane_db">
      <mxGeometry x="860" y="40" width="100" height="70" as="geometry"/>
    </mxCell>
    <mxCell id="respond" value="HTTP 201 Created with Application JSON" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="lane_controller">
      <mxGeometry x="1020" y="45" width="140" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="success" value="Show Application Pending Status" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="lane_client">
      <mxGeometry x="1020" y="45" width="140" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="edge1" edge="1" parent="1" source="start" target="route" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="edge2" edge="1" parent="1" source="route" target="jwt" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="edge3" edge="1" parent="1" source="jwt" target="check_exist" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="edge4" edge="1" parent="1" source="check_exist" target="db_check" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="edge5" edge="1" parent="1" source="db_check" target="create_app" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="edge6" edge="1" parent="1" source="create_app" target="db_insert" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="edge7" edge="1" parent="1" source="db_insert" target="respond" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="edge8" edge="1" parent="1" source="respond" target="success" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
  </root>
</mxGraphModel>
