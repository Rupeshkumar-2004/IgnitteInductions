    </mxCell>
    <mxCell id="node_zod" value="Zod Validator (registerSchema / loginSchema)" style="rhombus;whiteSpace=wrap;html=1;" vertex="1" parent="lane_mid">
      <mxGeometry x="660" y="35" width="140" height="80" as="geometry"/>
    </mxCell>
    <mxCell id="node_controller" value="auth.controller (registerUser / loginUser)" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="lane_ctrl">
      <mxGeometry x="840" y="45" width="140" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="node_check_db" value="Find / Create User Record" style="shape=cylinder3;whiteSpace=wrap;html=1;" vertex="1" parent="lane_db">
      <mxGeometry x="860" y="40" width="100" height="70" as="geometry"/>
    </mxCell>
    <mxCell id="node_tokens" value="generateAccessAndRefreshTokens()" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="lane_ctrl">
      <mxGeometry x="1020" y="45" width="140" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="node_save_token" value="Save RefreshToken in DB" style="shape=cylinder3;whiteSpace=wrap;html=1;" vertex="1" parent="lane_db">
      <mxGeometry x="1040" y="40" width="100" height="70" as="geometry"/>
    </mxCell>
    <mxCell id="node_response" value="HTTP Response (Set cookies + JSON data)" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="lane_ctrl">
      <mxGeometry x="1200" y="45" width="140" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="node_context" value="AuthContext updates React state" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="lane_fe">
