    </mxCell>
    <mxCell id="lane_db" value="Database (MongoDB)" style="swimlane;horizontal=0;startSize=110;fillColor=#e8f5e9;html=1;" vertex="1" parent="1">
      <mxGeometry x="0" y="450" width="2300" height="150" as="geometry"/>
    </mxCell>
    <mxCell id="node_start" value="User registers or logins (UI Forms)" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="lane_fe">
      <mxGeometry x="120" y="45" width="140" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="node_submit" value="Submit Form Data (FullName, Email, Password...)" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="lane_fe">
      <mxGeometry x="300" y="45" width="140" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="node_route" value="POST /register or /login (Express Routes)" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="lane_mid">
